<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.studyumbackend.chat.model.mapper.ChatMapper">
    <!-- =================
           chatRoom
    ================= -->
    <!-- 채팅방 생성 -->
    <insert id="insertChatRoom" parameterType="ChatRoom" useGeneratedKeys="true" keyProperty="chatRoomId" keyColumn="chat_room_id">
        INSERT INTO chat_room(
            category_id,
            chat_room_name,
            chat_room_description,
            chat_room_image,
            chat_room_visibility,
            chat_room_max_member,
            chat_room_current_member,
            chat_room_recruit_status
        )
        VALUES(#{categoryId}, #{chatRoomName}, #{chatRoomImage}, #{chatRoomVisibility}, #{chatRoomMaxMember},
               #{chatRoomCurrentMember}, #{chatRoomRecruitStatus})
    </insert>

    <!-- 채팅방 목록 검색 : 카테고리/검색어 -->
    <select id="selectChatRoomList" parameterType="ChatRoomSearchRequest" resultType="ChatRoomSearchResponse">
        SELECT
            cr.chat_room_id,
            cr.chat_room_name,
            cr.chat_room_description,
            cr.chat_room_image,
            cr.chat_room_visibility,
            cr.chat_room_current_member,
            cr.chat_room_max_member,
            cr.chat_room_recruit_status,
            cr.chat_room_created_at,
            c.category_name
        FROM chat_room cr
        INNER JOIN category c ON cr.category_id = c.category_id
        <where>
            cr.chat_room_recruit_status != 'DELETED'
            <if test="categoryId != null and categoryId != ''">
                AND cr.category_id = #{categoryId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND cr.chat_room_name LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="status != null and status != ''">
                AND cr.chat_room_recruit_status = #{status}
            </if>
        </where>
        ORDER BY cr.chat_room_created_at DESC
    </select>

    <!-- 본인 채팅방 목록 조회 -->
    <select id="selectChatRoomListByUserId" resultType="ChatRoomListDTO">
        SELECT *
        FROM v_chat_room_list
        WHERE user_id = #{userId}
    </select>

    <!-- 채팅방 상세 조회 -->
    <!-- 1. 채팅방 기본 정보 조회 -->
    <select id="findChatRoomById" resultType="ChatRoom">
        SELECT *
        FROM chat_room
        WHERE chat_room_id = #{chatRoomId}
    </select>
