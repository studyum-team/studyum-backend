    <!-- 채팅방 정보 수정 -->
    <update id="updateChatRoomInfoById">
        UPDATE chat_room
        SET chat_room_name = #{chatRoomName},
            chat_room_description = #{chatRoomDescription},
            chat_room_max_member = #{chatRoomMaxMember},
            chat_room_recruit_status = #{chatRoomRecruitStatus}
        WHERE chat_room_id = #{chatRoomId}
    </update>

    <!-- 채팅방 삭제 (소프트 삭제) -->
    <update id="deleteChatRoom">
        UPDATE chat_room
        SET chat_room_recruit_status = 'DELETED'
        WHERE chat_room_id = #{chatRoomId}
    </update>

    <!-- 유저 권한 검증 : chatRoomId와 userId로 필터링 -->
    <select id="selectUserRoleByChatRoomId">
        SELECT chat_room_user_role
        FROM chat_room_user
        WHERE chat_room_id = #{chatRoomId}
          AND user_id = #{userId}
    </select>


    <!-- =================
        chatRoomUser
    ================= -->
    <!-- 채팅방 멤버 목록 조회 -->
    <resultMap id="ChatRoomMemberResultMap" type="ChatRoomMemberResponse">
        <id     property="chatRoomUserId"       column="chat_room_user_id"/>
        <result property="chatRoomUserRole"     column="chat_room_user_role"/>
        <result property="chatRoomUserJoinedAt" column="chat_room_user_joined_at"/>

        <!-- 중첩 객체 매핑 -->
        <association property="user" javaType="ChatRoomSingleUserResponse">
            <id     property="userId"           column="user_id"/>
            <result property="userName"         column="user_name"/>
            <result property="userProfileImage" column="user_profile_image"/>
        </association>
    </resultMap>
    <select id="selectChatRoomUserListByChatRoomId" resultMap="ChatRoomMemberResultMap">
        SELECT
            chat_room_user_id,
            chat_room_user_role,
            chat_room_user_joined_at,
            user_id,
            user_nickname,
            user_profile_image
        FROM v_chat_room_members
        WHERE chat_room_id = #{chatRoomId}
    </select>

    <!-- 멤버 역할 변경 -->
    <update id="updateChatRoomUserRole">
        UPDATE chat_room_user
        SET chat_room_user_role = #{chatRoomUserRole}
        WHERE user_id = #{userId}
    </update>

    <!-- 멤버 강퇴 -->
    <delete id="deleteUserFromChatRoom">
        DELETE FROM chat_room_user
        WHERE chat_room_user_id = #{chatRoomUserId}
    </delete>

    <!-- 채팅방 나가기 (본인) -->
    <delete id="deleteMyselfFromChatRoom">
        DELETE FROM chat_room_user
        WHERE user_id = #{userId}
          AND chat_room_id = #{chatRoomId}
    </delete>


