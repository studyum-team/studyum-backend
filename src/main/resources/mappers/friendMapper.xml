<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.studyumbackend.friend.model.mapper.FriendMapper">

    <!-- 친구목록 추가 -->
    <insert id="insertFriend" parameterType="Friend" useGeneratedKeys="true" keyProperty="friendRelationId"
            keyColumn="friend_relation_id">
        INSERT INTO friend (user_id, friend_id)
        VALUES (#{userId}, #{friend_id})
    </insert>

    <!-- 친구목록 조회 -->
    <select id="selectFriend" resultType="Friend">
        SELECT *
        FROM friend
        WHERE user_id = #{userId}
    </select>

    <!-- 친구목록 삭제 -->
    <delete id="deleteFriend">
        DELETE
        FROM friend
        WHERE friend_relation_id = #{friendRelationId}
    </delete>

    <!-- 친구 요청 신청 -->
    <insert id="insertFriendRequest" parameterType="FriendRequest" useGeneratedKeys="true" keyProperty="friendRequestId" keyColumn="friend_request_id">
        INSERT INTO friend_request (requester_id, receiver_id)
        VALUES (#{requesterId}, #{receiverId})
    </insert>

    <!-- 친구 요청 신청 취소 -->
    <update id="deleteFriendRequest">
        UPDATE friend_request
        SET friend_request_status = 'CANCELED'
        WHERE friend_request_id = #{friendRequestId}
    </update>

    <!-- 친구 요청 신청 수락 -->
    <update id="updateFriendRequestStatusToAccepted">
        UPDATE friend_request
        SET friend_request_status = 'ACCEPTED'
        WHERE friend_request_id = #{friendRequestId}
    </update>

    <!-- 친구 요청 신청 거절 -->
    <update id="updateFriendRequestStatusToRejected">
        UPDATE friend_request
        SET friend_request_status = 'REJECTED'
        WHERE friend_request_id = #{friendRequestId}
    </update>

    <!-- 친구 요청 신청 목록 조회 -->
    <select id="selectFriendRequestByRequesterId" resultType="FriendRequest">
        SELECT *
        FROM friend_request
        WHERE requester_id = #{requesterId}
        AND friend_request_status = 'PENDING'
    </select>

    <!-- 친구 요청 수신 목록 조회 -->
    <select id="selectFriendRequestByReceiverId" resultType="FriendRequest">
        SELECT *
        FROM friend_request
        WHERE receiver_id = #{receiverId}
          AND friend_request_status = 'PENDING'
    </select>

</mapper>
